function dualariGuncelle() {
    const simdi = new Date();
    const saat = simdi.getHours();
    const dakika = simdi.getMinutes();
    const toplamDakika = (saat * 60) + dakika;

    const baslik = document.getElementById("dua-baslik");
    const arapca = document.getElementById("dua-arapca");
    const turkce = document.getElementById("dua-turkce");

    // 06:40 uyanma duası (400. dakika)
    if (toplamDakika >= 400 && toplamDakika < 420) {
        baslik.innerText = "Uyanma Duası";
        arapca.innerText = "الحَمْدُ لِلهِ الّذي أحْيانا بَعْدَ ما أماتَna وَإليه النّشور... (ve devamı)";
        turkce.innerText = "Bizi öldürdükten sonra dirilten Allah'a hamd olsun...";
    } 
    // 07:00 evden çıkış duası (420. dakika)
    else if (toplamDakika >= 420 && toplamDakika < 480) {
        baslik.innerText = "Evden Çıkış Duası";
        arapca.innerText = "بسم اللّٰه توكلت على اللّٰه ولا حول ولا قوة إلا بالله";
        turkce.innerText = "Allah'ın adıyla, Allah'a tevekkül ettim...";
    }
    else {
        baslik.innerText = "Hayırlı Günler";
        arapca.innerText = "لا إلهَ إلاّ اللهُ";
        turkce.innerText = "Zikirle kalbinizi ferahlatın...";
    }
}

// Her dakika kontrol et
setInterval(dualariGuncelle, 60000);
dualariGuncelle();

// Bildirim İzni ve Gönderimi (Tarayıcı destekliyorsa)
function bildirimGonder(mesaj) {
    if (Notification.permission === "granted") {
        new Notification("Dualarımız Unutmayalım", { body: mesaj });
    } else if (Notification.permission !== "denied") {
        Notification.requestPermission();
    }
}
