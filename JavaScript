// Sayfa açılır açılmaz izin iste
window.onload = function() {
    if ("Notification" in window) {
        Notification.requestPermission().then(permission => {
            if (permission === "granted") {
                console.log("Bildirim izni alındı.");
            }
        });
    }
};

function dualariGuncelle() {
    const simdi = new Date();
    const saat = simdi.getHours();
    const dakika = simdi.getMinutes();

    const baslik = document.getElementById("dua-baslik");
    const arapca = document.getElementById("dua-arapca");

    // 06:40 Uyanma Duası
    if (saat === 6 && dakika === 40) {
        baslik.innerText = "Uyanma Duası";
        arapca.innerText = "الحَمْدُ لِلهِ الّذي أحْيانا بَعْدَ ما أماتَنا وَإليه النّشور...";
        bildirimGonder("Uyanma vakti: Dualarını unutma!");
    } 
    // 07:00 Evden Çıkış Duası
    else if (saat === 7 && dakika === 0) {
        baslik.innerText = "Evden Çıkış Duası";
        arapca.innerText = "بسم اللّٰه توكلت على اللّٰه...";
        bildirimGonder("Evden çıkış vakti: Allah'a emanet ol.");
    }
}

function bildirimGonder(mesaj) {
    if (Notification.permission === "granted") {
        new Notification("Dualarımız Unutmayalım", {
            body: mesaj,
            icon: "https://via.placeholder.com/128"
        });
    }
}

setInterval(dualariGuncelle, 30000); // 30 saniyede bir kontrol et
dualariGuncelle();
